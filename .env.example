# GRC Dashboard — Environment Variables
# Copy this file to .env and fill in values for your environment.
# The app works out-of-the-box without a .env using SQLite defaults.

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default — no config needed):
# DATABASE_URL=sqlite:///backend/grc.db

# PostgreSQL (set this to switch from SQLite):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/grc_db

# ─── Application ─────────────────────────────────────────────────────────────
# SESSION_SECRET=change-me-in-production
